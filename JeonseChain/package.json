{
  "name": "jeonsechain",
  "private": true,
  "version": "1.0.0",
  "description": "Smart-contract and oracle workspace for JeonseChain",
  "type": "module",
  "scripts": {
    "clean": "hardhat clean",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "keeper:settlement": "node scripts/settlement-keeper.js",
    "oracle:fetch": "node scripts/oracle-fetcher.js",
    "oracle:watch": "node scripts/oracle-fetcher.js --config ./config/oracle-properties.sample.json --watch --save-report",
    "demo:e2e": "hardhat run scripts/demo-e2e.js --network hardhat",
    "demo:e2e:sepolia": "hardhat run scripts/demo-e2e.js --network sepolia"
  },
  "license": "ISC",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "dotenv": "^17.3.1",
    "hardhat": "^2.28.6",
    "solc": "^0.8.34"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1"
  }
}
