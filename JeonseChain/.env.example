# MetaMask 개인키 (앞에 0x 포함)
# 주의: 절대 깃에 올리지 말 것. .gitignore에 .env 추가 필수
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Sepolia RPC URL (Alchemy 추천: https://dashboard.alchemy.com/)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# 공공데이터포털 API 키 (국토부 실거래가 / 전월세 OpenAPI)
DATA_GO_KR_API_KEY=YOUR_DATA_GO_KR_API_KEY

# 한국은행 ECOS API 키 (선택, 금리/수익률 벤치마크용)
BOK_ECOS_API_KEY=YOUR_BOK_ECOS_API_KEY

# GitHub 공개 snapshot 동기화용 (선택)
GITHUB_TOKEN=YOUR_GITHUB_TOKEN
GITHUB_REPO_OWNER=YOUR_GITHUB_OWNER
GITHUB_REPO_NAME=jeonsechain
GITHUB_REPO_BRANCH=main
GITHUB_REPO_SNAPSHOT_PATH=oracle-live/latest.json

# Etherscan API 키 (선택, 컨트랙트 검증용)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY
